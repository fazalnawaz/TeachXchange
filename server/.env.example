PORT=3001
MONGO_URI=mongodb://localhost:27017/fyp
JWT_SECRET=your_jwt_secret_here

# Hugging Face Inference Providers (token needs "Inference Providers" permission)
# https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_token_here
# Router API (replaces retired api-inference.huggingface.co)
HF_ROUTER_URL=https://router.huggingface.co/v1
HF_INFERENCE_URL=https://router.huggingface.co/hf-inference
# Chat models (:fastest added automatically for provider routing)
HF_MODEL=Qwen/Qwen2.5-7B-Instruct-1M
HF_FALLBACK_MODEL=google/gemma-2-2b-it

# CORS / Socket.io (client URL)
CLIENT_URL=http://localhost:5173

# ZEGOCloud video (https://console.zegocloud.com)
ZEGO_APP_ID=
ZEGO_SERVER_SECRET=
